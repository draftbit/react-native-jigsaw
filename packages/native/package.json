{
  "name": "@draftbit/native",
  "version": "56.0.2",
  "description": "Draftbit UI Components that Depend on Native Components",
  "main": "./src/index.tsx",
  "react-native": "./src/index.tsx",
  "types": "lib/typescript/src/index.d.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "clean": "rimraf lib",
    "clean:modules": "rimraf node_modules",
    "build": "yarn clean && yarn tsc",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/draftbit/react-native-jigsaw",
    "directory": "packages/native"
  },
  "author": "Draftbit <services@draftbit.com> (https://draftbit.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/draftbit/react-native-jigsaw/issues"
  },
  "homepage": "https://github.com/draftbit/react-native-jigsaw#readme",
  "dependencies": {
    "@draftbit/theme": "56.0.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/slider": "5.2.0",
    "expo-camera": "~56.0.8",
    "expo-linear-gradient": "~56.0.4",
    "react-native-svg": "15.15.4",
    "react-native-webview": "13.16.1"
  },
  "jest": {
    "preset": "jest-expo",
    "globalSetup": "<rootDir>/../../jest/global-setup.js",
    "testPathIgnorePatterns": [
      "lib",
      "__mocks__"
    ]
  }
}
